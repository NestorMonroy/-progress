{
  "name": "@progress/kno-pdfviewer-common",
  "description": "Kno UI TypeScript package exporting functions for PDFViewer component",
  "version": "1.0.0",
  "keywords": [
    "Kno UI"
  ],
  "author": "Progress",
  "license": "SEE LICENSE IN LICENSE.md",
  "main": "dist/npm/main.js",
  "module": "dist/es/main.js",
  "es2015": "dist/es2015/main.js",
  "typings": "dist/npm/main.d.ts",
  "engines": {
    "npm": ">=8.0.0",
    "node": ">=18.0.0"
  },
  "scripts": {
    "prepare": "npx husky",
    "test": "vitest run --config vitest.config.ts",
    "test:ci": "vitest run --config vitest.config.ts",
    "watch-test": "vitest run --config vitest.config.ts --watch",
    "start": "cross-env NODE_OPTIONS=--openssl-legacy-provider gulp start",
    "lint": "npx eslint",
    "lint:fix": "npx eslint --fix",
    "api-check": "gulp api-check",
    "build-package": "cross-env NODE_OPTIONS=--openssl-legacy-provider gulp build-ts-package"
  },
  "peerDependencies": {
    "@progress/kno-draggable": "^3.1.0",
    "@progress/kno-file-saver": "^1.1.2"
  },
  "dependencies": {
    "@progress/kno-common": "1.0.2",
    "pdfjs-dist": "5.6.205",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@eslint/js": "^10.0.1",
    "@progress/kno-common-tasks": "^9.0.1",
    "@progress/kno-draggable": "^3.1.0",
    "@progress/kno-file-saver": "^1.1.2",
    "@progress/kno-typescript-tasks": "^12.0.0",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.0.3",
    "eslint-plugin-jsdoc": "^62.8.0",
    "gulp": "^5.0.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.1.3",
    "vitest-canvas-mock": "^1.1.3"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "overrides": {
    "lodash": "^4.17.23",
    "inquirer": "^9.2.0",
    "uuid": "^14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tlk/kno-pdfviewer-common.git"
  },
  "bugs": {
    "url": "https://github.com/tlk/kno-angular"
  },
  "files": [
    "dist"
  ]
}
