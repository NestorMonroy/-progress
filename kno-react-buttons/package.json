{
  "name": "@progress/kno-react-buttons",
  "version": "15.0.0",
  "description": "All you need in React Button in one package: disabled/enabled states, built-in styles and more. knoReact Buttons package",
  "author": "Progress",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "/kno-react-ui",
  "main": "./index.js",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      },
      "require": {
        "types": "./index.d.ts",
        "default": "./index.js"
      }
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "sideEffects": false,
  "peerDependencies": {
    "@progress/kno-smartpaste-common": "1.0.0",
    "@progress/kno-licensing": "^1.7.2",
    "@progress/kno-webspeech-common": "^1.0.1",
    "@progress/kno-react-common": "15.0.0",
    "@progress/kno-react-intl": "15.0.0",
    "@progress/kno-react-popup": "15.0.0",
    "@progress/kno-svg-icons": "^4.9.0 || ^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "prop-types": "^15.6.0"
  },
  "keywords": [
    "Kno UI",
    "React",
    "Progress",
    "Buttons",
    "knoReact",
    "",
    "reactjs",
    "UI",
    "components",
    "React component",
    "",
    "button group",
    "chip",
    "chip list",
    "dropdown button",
    "floating action button",
    "split button",
    "toolbar",
    "Telerik"
  ],
  "@progress": {
    "friendlyName": "Buttons",
    "framework": "knoReact",
    "migrations": {
      "options": {
        "parser": "tsx",
        "pattern": "*.{js,jsx,ts,tsx}"
      },
      "codemods": {
        "15": [
          {
            "description": "Remove deprecated themeColor values ('dark', 'light') from Button, DropDownButton, and SplitButton. Valid values: 'base' | 'primary' | 'secondary' | 'tertiary' | 'info' | 'success' | 'warning' | 'error' | 'inverse'.",
            "file": "codemods/v15/theme-color",
            "prompt": true
          },
          {
            "description": "Remove deprecated themeColor values from FloatingActionButton. Valid values: 'base' | 'primary' | 'secondary' | 'tertiary'.",
            "file": "codemods/v15/fab-theme-color",
            "prompt": true
          }
        ]
      }
    },
    "package": {
      "productName": "knoReact",
      "productCode": "knoUIREACT",
      "publishDate": 1779275304,
      "licensingDocsUrl": ""
    }
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependenciesMeta": {
    "@progress/kno-svg-icons": {
      "optional": true
    }
  }
}