{
  "name": "@progress/kno-react-layout",
  "version": "15.0.0",
  "description": "React Layout components enable you to create a perceptive and intuitive layout of web projects. knoReact Layout package",
  "author": "Progress",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "/kno-react-ui",
  "main": "./index.js",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      },
      "require": {
        "types": "./index.d.ts",
        "default": "./index.js"
      }
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "sideEffects": false,
  "peerDependencies": {
    "@progress/kno-licensing": "^1.7.2",
    "@progress/kno-react-animation": "15.0.0",
    "@progress/kno-react-buttons": "15.0.0",
    "@progress/kno-react-common": "15.0.0",
    "@progress/kno-react-intl": "15.0.0",
    "@progress/kno-react-popup": "15.0.0",
    "@progress/kno-react-progressbars": "15.0.0",
    "@progress/kno-svg-icons": "^4.9.0 || ^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "prop-types": "^15.6.0"
  },
  "keywords": [
    "Kno UI",
    "React",
    "Progress",
    "TabStrip",
    "PanelBar",
    "Splitter",
    "Menu",
    "Drawer",
    "knoReact",
    "",
    "reactjs",
    "UI",
    "components",
    "React component",
    "free React component",
    "layout",
    "action sheet",
    "app bar",
    "bottom navigation",
    "breadcrumb",
    "card",
    "context menu",
    "expansion panel",
    "grid layout",
    "stack layout",
    "stepper",
    "tile layout",
    "timeline",
    "Telerik"
  ],
  "@progress": {
    "friendlyName": "Layout",
    "framework": "knoReact",
    "migrations": {
      "options": {
        "parser": "tsx",
        "pattern": "*.{js,jsx,ts,tsx}"
      },
      "codemods": {
        "15": [
          {
            "description": "Remove deprecated themeColor values from AppBar. Valid values: 'base' | 'primary' | 'secondary' | 'tertiary' | 'inverse'.",
            "file": "codemods/v15/appbar-theme-color",
            "prompt": true
          },
          {
            "description": "Remove deprecated themeColor values from Avatar. Valid values: 'base' | 'primary' | 'secondary' | 'tertiary'.",
            "file": "codemods/v15/avatar-theme-color",
            "prompt": true
          },
          {
            "description": "Remove deprecated themeColor values from BottomNavigation. Valid values: 'base' | 'primary' | 'secondary' | 'tertiary' | 'inverse'.",
            "file": "codemods/v15/bottomnav-theme-color",
            "prompt": true
          }
        ]
      }
    },
    "package": {
      "productName": "knoReact",
      "productCode": "knoUIREACT",
      "publishDate": 1779275343,
      "licensingDocsUrl": ""
    }
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependenciesMeta": {
    "@progress/kno-svg-icons": {
      "optional": true
    }
  }
}