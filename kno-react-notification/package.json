{
  "name": "@progress/kno-react-notification",
  "version": "15.0.0",
  "description": "React Notification renders a message to the user with information about the status of an app process. knoReact Notification package",
  "author": "Progress",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "/kno-react-ui",
  "main": "./index.js",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      },
      "require": {
        "types": "./index.d.ts",
        "default": "./index.js"
      }
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "sideEffects": false,
  "peerDependencies": {
    "@progress/kno-licensing": "^1.7.2",
    "@progress/kno-react-common": "15.0.0",
    "@progress/kno-svg-icons": "^4.9.0 || ^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "prop-types": "^15.6.0"
  },
  "keywords": [
    "Kno UI",
    "React",
    "Progress",
    "notification",
    "knoReact",
    "",
    "reactjs",
    "UI",
    "components",
    "React component",
    "free React component",
    "Telerik"
  ],
  "@progress": {
    "friendlyName": "Notification",
    "framework": "knoReact",
    "migrations": {
      "options": {
        "parser": "tsx",
        "pattern": "*.{js,jsx,ts,tsx}"
      },
      "codemods": {
        "15": [
          {
            "description": "Remove deprecated type.style values ('dark', 'light') from Notification. Valid values: 'base' | 'primary' | 'secondary' | 'tertiary' | 'info' | 'success' | 'warning' | 'error' | 'inverse' | 'none'.",
            "file": "codemods/v15/notification-type-style",
            "prompt": true
          }
        ]
      }
    },
    "package": {
      "productName": "knoReact",
      "productCode": "knoUIREACT",
      "publishDate": 1779275497,
      "licensingDocsUrl": ""
    }
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependenciesMeta": {
    "@progress/kno-svg-icons": {
      "optional": true
    }
  }
}