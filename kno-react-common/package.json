{
  "name": "@progress/kno-react-common",
  "version": "15.0.0",
  "description": "React Common package delivers common utilities that can be used with the knoReact UI components. knoReact Common Utilities package",
  "author": "Progress",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "/kno-react-ui",
  "main": "./index.js",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      },
      "require": {
        "types": "./index.d.ts",
        "default": "./index.js"
      }
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "sideEffects": false,
  "peerDependencies": {
    "@progress/kno-licensing": "^1.7.2",
    "@progress/kno-svg-icons": "^4.9.0 || ^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@progress/kno-draggable-common": "^0.2.3",
    "prop-types": "^15.6.0"
  },
  "keywords": [
    "Kno UI",
    "React",
    "Progress",
    "Utilities",
    "knoReact",
    "",
    "reactjs",
    "UI",
    "components",
    "React component",
    "free React component",
    "Telerik"
  ],
  "@progress": {
    "friendlyName": "Common",
    "framework": "knoReact",
    "migrations": {
      "options": {
        "parser": "tsx",
        "pattern": "*.{js,jsx,ts,tsx}"
      },
      "codemods": {
        "15": [
          {
            "description": "Rename removed/deprecated SVG icon imports from @progress/kno-svg-icons v4 to v5. Updates import specifiers (e.g., caretAltDownIcon → chevronDownIcon) and icon string props (e.g., icon=\"caret-alt-down\" → icon=\"chevron-down\"). Adds TODO comments for icons removed without replacement.",
            "file": "codemods/v15/icon-rename",
            "prompt": true
          },
          {
            "description": "Remove deprecated themeColor values ('dark', 'light') from Icon and SvgIcon. Valid values: 'inherit' | 'primary' | 'secondary' | 'tertiary' | 'info' | 'success' | 'warning' | 'error' | 'inverse'.",
            "file": "codemods/v15/icon-theme-color",
            "prompt": true
          }
        ]
      }
    }
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependenciesMeta": {
    "@progress/kno-svg-icons": {
      "optional": true
    }
  }
}