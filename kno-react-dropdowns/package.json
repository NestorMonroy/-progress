{
  "name": "@progress/kno-react-dropdowns",
  "version": "15.0.0",
  "description": "React DropDowns offer an interface for users to select different items from a list and more. knoReact Dropdowns package",
  "author": "Progress",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "/kno-react-ui",
  "main": "./index.js",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      },
      "require": {
        "types": "./index.d.ts",
        "default": "./index.js"
      }
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "sideEffects": false,
  "peerDependencies": {
    "@progress/kno-licensing": "^1.7.2",
    "@progress/kno-react-buttons": "15.0.0",
