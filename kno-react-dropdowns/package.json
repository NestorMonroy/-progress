    "@progress/kno-react-inputs": "15.0.0",
    "@progress/kno-react-intl": "15.0.0",
    "@progress/kno-react-labels": "15.0.0",
    "@progress/kno-react-layout": "15.0.0",
    "@progress/kno-react-popup": "15.0.0",
    "@progress/kno-react-treeview": "15.0.0",
    "@progress/kno-svg-icons": "^4.9.0 || ^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "prop-types": "^15.6.0"
  },
  "keywords": [
    "Kno UI",
    "React",
    "knoReact",
    "",
    "reactjs",
    "UI",
    "components",
    "React component",
    "free React component",
    "Telerik",
    "Dropdowns",
    "AutoComplete",
    "ComboBox",
    "DropDownList",
    "MultiSelect",
    "DropDownTree",
    "MultiColumnComboBox",
    "MultiSelectTree"
  ],
  "@progress": {
    "friendlyName": "Dropdowns",
    "framework": "knoReact",
    "migrations": {
      "options": {
        "parser": "tsx",
        "pattern": "*.{js,jsx,ts,tsx}"
      },
      "codemods": {
        "14": [
          {
            "description": "Remove deprecated groupMode prop from ComboBox, DropDownList, MultiSelect, MultiColumnComboBox, and AutoComplete. Modern grouping is now the only available mode.",
            "file": "codemods/v14/group-mode",
            "prompt": true
          }
        ]
      }
    },
    "package": {
      "productName": "knoReact",
      "productCode": "knoUIREACT",
      "publishDate": 1779275426,
      "licensingDocsUrl": "?utm_medium=product&utm_source=knoreact&utm_campaign=kno-ui-react-purchase-license-keys-warning"
    }
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependenciesMeta": {
    "@progress/kno-svg-icons": {
      "optional": true
    }
  }
